# Copy this file to .env and fill in real values. Never commit the real .env file.

PORT=3000
NODE_ENV=development

# --- Database --------------------------------------------------------------------
# Local MongoDB: mongodb://127.0.0.1:27017/echo_feedback
# MongoDB Atlas (free tier): mongodb+srv://<user>:<password>@<cluster>.mongodb.net/echo_feedback
MONGODB_URI=mongodb://127.0.0.1:27017/echo_feedback

# Long random string used to sign admin session cookies.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# --- Admin panel (http://localhost:3000/admin) ---------------------------------
# Generate a hash for your chosen password with:
#   npm run hash-password -- "your-chosen-password"
# then paste the printed value below.
ADMIN_PASSWORD_HASH=

# --- Email notifications --------------------------------------------------------
# Sent to ADMIN_EMAIL every time someone posts new feedback.
# Leave SMTP_HOST blank to disable email notifications (feedback still saves fine).
ADMIN_EMAIL=you@example.com
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Echo Feedback <no-reply@example.com>"

# --- Deployment ------------------------------------------------------------------
# In production, set this to your real site URL to lock down CORS, e.g.
# ALLOWED_ORIGIN=https://feedback.yoursite.com
ALLOWED_ORIGIN=
